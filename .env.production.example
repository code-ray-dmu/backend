NODE_ENV=production
PORT=3000

DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=code_ray

REDIS_HOST=your-redis-host
REDIS_PORT=6379

RABBITMQ_URL=amqp://user:password@your-rabbitmq-host:5672
RABBITMQ_DEFAULT_USER=user
RABBITMQ_DEFAULT_PASS=password

JWT_ACCESS_SECRET=your-strong-access-secret
JWT_REFRESH_SECRET=your-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=14d

GITHUB_TOKEN=your-github-token

LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name
LLM_MAX_RETRIES=2
LLM_TIMEOUT_MS=30000

MAX_REPO_SELECTION_COUNT=3
MAX_ANALYSIS_FILES=10
MAX_QUESTIONS_PER_ANALYSIS_RUN=3

RABBITMQ_MAX_RETRY=2
ANALYSIS_LOCK_TTL=600
ANALYSIS_CLEANUP_INTERVAL_SECONDS=300
ANALYSIS_STALE_RUN_THRESHOLD_SECONDS=1800
ANALYSIS_CLEANUP_BATCH_SIZE=50
